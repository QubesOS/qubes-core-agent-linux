#!/usr/bin/python3 --

import sys, os, pwd
import qubesdb
from qubesagent.xdg import launch

def main(argv):
    try:
        (arg0, arg,) = argv
    except ValueError:
        print('This service requires an argument', file=sys.stderr)
        sys.exit(1)
    try:
        xdg_data_home = os.environ['XDG_DATA_HOME']
    except KeyError:
        xdg_data_home = os.path.expanduser('~/.local/share')
        if xdg_data_home[0] != '/':
            raise OSError('cannot expand ~/.local/share')
    try:
        xdg_data_dirs = os.environ['XDG_DATA_DIRS']
    except KeyError:
        xdg_data_dirs = ['/usr/local/share','/usr/share']
    else:
        if '::' in xdg_data_dirs or \
                xdg_data_dirs.startswith(':') or \
                xdg_data_dirs.endswith(':'):
            print('Empty entries in XDG_DATA_DIRS not allowed')
            sys.exit(1)
        xdg_data_dirs = xdg_data_dirs.split(':')
    paths_to_try = [xdg_data_home] + xdg_data_dirs
    qubes_db = qubesdb.QubesDB()
    if qubes_db.read('/qubes-service/app-dispvm.' + arg) is not None:
        try:
            del os.environ['XDG_DATA_HOME']
        except KeyError:
            pass
        os.environ['XDG_DATA_DIRS'] = '/usr/share/qubes/mime'
    for path in paths_to_try:
        subpath = os.path.join(path, 'applications')
        for (raw_volume, directories, files) in os.walk(subpath):
            volume = raw_volume[len(subpath):]
            if volume:
                volume = volume[1:].replace('/', '-') + '-'
            for f in files:
                if not f.endswith('.desktop'):
                    continue
                the_id = volume + f[:-8]
                if the_id == arg:
                    launch(os.path.join(raw_volume, f))
                    return
    print(arg, 'not found in', ':'.join(paths_to_try))
    sys.exit(1)

if __name__ == '__main__':
    main(sys.argv)
